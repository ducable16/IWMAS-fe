  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint src --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "check:no-js-source": "node -e \"const fs=require('fs');const path=require('path');const out=[];function walk(d){for(const e of fs.readdirSync(d,{withFileTypes:true})){const p=path.join(d,e.name);if(e.isDirectory())walk(p);else if(/\\.(js|jsx)$/.test(e.name))out.push(p)}}walk('src');if(out.length){console.error(out.join('\\n'));process.exit(1)}\""
  },
